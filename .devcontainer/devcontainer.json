{
  "name": "Versailles Agentic Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-github-actions",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode",
        "yzhang.markdown-all-in-one",
        "bierner.markdown-mermaid",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "github.copilot.enable": {
          "*": true
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "npm install -g pnpm @claude-flow/cli@latest && echo '✅ Ruflo/claude-flow installed:' && (ruflo --version 2>/dev/null || claude-flow --version 2>/dev/null || echo 'available via npx') && bash harness/agent-bootstrap.sh",
  "postStartCommand": "echo '🏰 Welcome to Versailles — your agentic environment is ready.' && echo '  Run: bash harness/agent-bootstrap.sh  to verify setup' && echo '  Run: ruflo swarm start --orchestrator claude-sonnet --workers 2 --task \"your task\" --context CLAUDE.md --max-agents 5  to launch a swarm'",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "VERSAILLES_ENV": "codespaces"
  },
  "forwardPorts": [3000, 8080],
  "portsAttributes": {
    "3000": {
      "label": "Agent Dashboard",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/Versailles,type=bind,consistency=cached"
  ]
}
